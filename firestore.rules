rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation for User
    function isValidUser(data) {
      return data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 100;
    }

    // Validation for Match
    function isValidMatch(data) {
      return data.date is timestamp &&
             data.goals is int && data.goals >= 0 && data.goals < 100 &&
             data.assists is int && data.assists >= 0 && data.assists < 100 &&
             data.rating is number && data.rating >= 0 && data.rating <= 10 &&
             data.userId == request.auth.uid &&
             (data.notes == null || (data.notes is string && data.notes.size() <= 1000));
    }

    // Routes
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false; // Users shouldn't be listable by default
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']);
    }

    match /users/{userId}/matches/{matchId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidMatch(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidMatch(incoming()) && 
                    incoming().userId == existing().userId &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time;
      allow delete: if isOwner(userId);
    }
  }
}
